# Backend (server/index.js) — clave secreta de Stripe, nunca la expongas en el frontend
STRIPE_SECRET_KEY=sk_test_...

# Frontend (Vite) — clave publicable de Stripe, es segura para exponer en el navegador
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Puerto del servidor Express (opcional)
PORT=8787

# Backend (server/index.js) — clave secreta de Paymento para crear sesiones
# de pago en cripto, nunca la expongas en el frontend.
PAYMENTO_API_KEY=...

# Backend — secreto para verificar la firma HMAC de los webhooks (IPN) de
# Paymento. Lo genera Paymento en su dashboard de merchant.
PAYMENTO_IPN_SECRET=...

# Opcionales: solo si Paymento te da URLs distintas a las de por defecto.
PAYMENTO_API_BASE_URL=https://api.paymento.io
PAYMENTO_GATEWAY_BASE_URL=https://app.paymento.io/gateway
