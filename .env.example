# Backend (server/index.js) — clave secreta de Stripe, nunca la expongas en el frontend
STRIPE_SECRET_KEY=sk_test_...

# Frontend (Vite) — clave publicable de Stripe, es segura para exponer en el navegador
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Puerto del servidor Express (opcional)
PORT=8787

# Backend (server/index.js) — clave secreta de Paymento para crear sesiones
# de pago en cripto, nunca la expongas en el frontend.
PAYMENTO_API_KEY=...

# Backend — secreto para verificar la firma HMAC de los webhooks (IPN) de
# Paymento. Lo genera Paymento en su dashboard de merchant.
PAYMENTO_IPN_SECRET=...

# Opcionales: solo si Paymento te da URLs distintas a las de por defecto.
PAYMENTO_API_BASE_URL=https://api.paymento.io
PAYMENTO_GATEWAY_BASE_URL=https://app.paymento.io/gateway

# Backend — secreto para verificar la firma de los webhooks de Stripe.
# Lo generas al crear el webhook en tu dashboard de Stripe (Developers →
# Webhooks), apuntando a "<tu dominio>/api/stripe-webhook".
STRIPE_WEBHOOK_SECRET=whsec_...

# Backend — cadena de conexión de tu base de datos Postgres (Neon/Vercel
# Postgres). Se usa para guardar cada solicitud de envío y que aparezca en
# el dashboard de admin en /rtx. Vercel la inyecta sola si conectas una base
# de datos desde la pestaña "Storage" de tu proyecto.
DATABASE_URL=postgres://...

# Backend — usuario y contraseña que piden para entrar a /rtx (autenticación
# HTTP básica, sin pantalla de login propia). Sin ADMIN_PASSWORD, /rtx no
# muestra nada.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=...
